page {
  --brand-red: #c61f1f;
  --brand-red-dark: #8f1010;
  --brand-gold: #f5c44f;
  --brand-gold-deep: #d8a126;
  --brand-soft: #fff8f6;
  --surface: #ffffff;
  --text-primary: #2a1b1b;
  --text-secondary: #6f5b5b;
  --text-muted: #9f8d8d;
  --line: #ead8d8;
  --success: #1f8a5b;
  --warning: #b86800;
  --danger: #c9372c;
  --shadow-card: 0 18rpx 48rpx rgba(90, 22, 22, 0.08);
  background:
    radial-gradient(circle at top, #fff4ef 0%, #f7f4f1 38%, #f3f2ef 100%);
  color: var(--text-primary);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea,
scroll-view,
navigator {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
}

.page-title {
  font-size: 44rpx;
  line-height: 1.3;
  font-weight: 700;
}

.page-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.card {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(198, 31, 31, 0.08);
  border-radius: 28rpx;
  box-shadow: var(--shadow-card);
}

.section-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.field-label {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.input-box,
.textarea-box,
.picker-box {
  width: 100%;
  min-height: 92rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid var(--line);
  background: var(--brand-soft);
  font-size: 28rpx;
  color: var(--text-primary);
}

.textarea-box {
  min-height: 200rpx;
}

.btn-primary,
.btn-secondary,
.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 1;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--brand-red) 0%, var(--brand-red-dark) 100%);
  color: #fff;
  box-shadow: 0 18rpx 40rpx rgba(198, 31, 31, 0.24);
}

.btn-secondary {
  background: #f7e6e6;
  color: var(--brand-red-dark);
}

.btn-ghost {
  background: transparent;
  color: var(--brand-red);
  border: 1rpx solid rgba(198, 31, 31, 0.24);
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.badge-primary {
  background: rgba(198, 31, 31, 0.12);
  color: var(--brand-red-dark);
}

.badge-success {
  background: rgba(31, 138, 91, 0.12);
  color: var(--success);
}

.badge-warning {
  background: rgba(184, 104, 0, 0.12);
  color: var(--warning);
}

.badge-danger {
  background: rgba(201, 55, 44, 0.12);
  color: var(--danger);
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.metric-card {
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255, 248, 246, 0.96) 0%, #fff 100%);
  border: 1rpx solid rgba(198, 31, 31, 0.08);
}

.metric-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.metric-value {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--brand-red-dark);
}

.metric-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.link-text {
  color: var(--brand-red);
  font-size: 26rpx;
}

.footer-note {
  margin-top: 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
}

.theme-toggle-hint {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.62);
}

.theme-classic .hero-slogan,
.theme-classic .dashboard-banner,
.theme-classic .workflow-banner,
.theme-classic .register-banner,
.theme-classic .detail-banner,
.theme-classic .profile-banner {
  display: none;
}

.theme-propaganda {
  position: relative;
}

.theme-propaganda .card {
  border: 2rpx solid rgba(216, 161, 38, 0.55);
  box-shadow: 0 24rpx 56rpx rgba(128, 18, 18, 0.12);
  background: linear-gradient(180deg, rgba(255, 248, 228, 0.98) 0%, rgba(255, 255, 255, 1) 100%);
}

.theme-propaganda .page-title,
.theme-propaganda .section-title,
.theme-propaganda .hero-title,
.theme-propaganda .dashboard-title,
.theme-propaganda .step-name,
.theme-propaganda .shortcut-title,
.theme-propaganda .sample-name {
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(113, 11, 11, 0.12);
}

.theme-propaganda .hero-panel,
.theme-propaganda .dashboard-hero {
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(135deg, #8f1010 0%, #bf1515 34%, #d82e22 72%, #8f1010 100%);
  color: #fff4d1;
}

.theme-propaganda .hero-panel::before,
.theme-propaganda .dashboard-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 10% 18%, rgba(255, 236, 173, 0.34) 0, rgba(255, 236, 173, 0) 18%),
    radial-gradient(circle at 90% 20%, rgba(255, 236, 173, 0.24) 0, rgba(255, 236, 173, 0) 16%),
    linear-gradient(90deg, rgba(255, 213, 94, 0) 0, rgba(255, 213, 94, 0.24) 50%, rgba(255, 213, 94, 0) 100%);
  pointer-events: none;
}

.theme-propaganda .hero-title,
.theme-propaganda .dashboard-title {
  color: #fff4d1;
  font-size: 48rpx;
  font-weight: 800;
}

.theme-propaganda .hero-subtitle,
.theme-propaganda .page-subtitle,
.theme-propaganda .dashboard-stage,
.theme-propaganda .metric-label,
.theme-propaganda .metric-desc,
.theme-propaganda .shortcut-desc,
.theme-propaganda .field-label,
.theme-propaganda .detail-label,
.theme-propaganda .step-phase,
.theme-propaganda .sample-desc,
.theme-propaganda .attachment-item,
.theme-propaganda .log-item {
  color: #681414;
}

.theme-propaganda .dashboard-hero .page-subtitle,
.theme-propaganda .dashboard-stage {
  color: rgba(255, 241, 201, 0.88);
}

.theme-propaganda .dashboard-stage {
  border-top-color: rgba(255, 216, 118, 0.35);
  font-weight: 600;
}

.theme-propaganda .hero-slogan,
.theme-propaganda .dashboard-banner,
.theme-propaganda .workflow-banner,
.theme-propaganda .register-banner,
.theme-propaganda .detail-banner,
.theme-propaganda .profile-banner {
  margin-top: 22rpx;
  padding: 14rpx 18rpx;
  border: 2rpx solid rgba(255, 225, 136, 0.6);
  background: linear-gradient(90deg, rgba(255, 219, 109, 0.2), rgba(255, 245, 213, 0.06));
  color: #ffe8a0;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  text-align: center;
}

.theme-propaganda .workflow-banner,
.theme-propaganda .register-banner,
.theme-propaganda .detail-banner,
.theme-propaganda .profile-banner {
  color: #781111;
  background: linear-gradient(90deg, rgba(255, 226, 134, 0.56), rgba(255, 245, 214, 0.9));
}

.theme-propaganda .section-card {
  padding: 32rpx;
}

.theme-propaganda .metric-card,
.theme-propaganda .detail-item,
.theme-propaganda .step-card {
  background:
    linear-gradient(180deg, rgba(255, 245, 214, 1) 0%, rgba(255, 255, 255, 1) 100%);
  border: 2rpx solid rgba(216, 161, 38, 0.42);
}

.theme-propaganda .metric-value {
  color: #a01717;
  font-size: 46rpx;
}

.theme-propaganda .badge-primary {
  background: linear-gradient(135deg, rgba(255, 214, 105, 0.26), rgba(255, 241, 199, 0.52));
  color: #741111;
}

.theme-propaganda .badge-success {
  background: rgba(255, 223, 133, 0.28);
  color: #7f5300;
}

.theme-propaganda .badge-warning {
  background: rgba(198, 31, 31, 0.14);
  color: #8c1414;
}

.theme-propaganda .badge-danger {
  background: rgba(147, 16, 16, 0.16);
  color: #6d0f0f;
}

.theme-propaganda .btn-primary {
  background: linear-gradient(180deg, #d62020 0%, #a81111 100%);
  border: 2rpx solid rgba(255, 221, 126, 0.52);
  box-shadow: 0 20rpx 40rpx rgba(161, 31, 31, 0.28);
}

.theme-propaganda .btn-secondary {
  background: linear-gradient(180deg, #ffe4a0 0%, #f7c85f 100%);
  color: #6d0f0f;
  border: 2rpx solid rgba(194, 37, 37, 0.32);
}

.theme-propaganda .btn-ghost {
  background: rgba(255, 244, 215, 0.86);
  border: 2rpx solid rgba(191, 21, 21, 0.38);
  color: #7a1414;
}

.theme-propaganda .input-box,
.theme-propaganda .textarea-box,
.theme-propaganda .picker-box {
  border: 2rpx solid rgba(216, 161, 38, 0.46);
  background: linear-gradient(180deg, #fff6de 0%, #fffef9 100%);
  color: #561212;
}

.theme-propaganda .sample-item,
.theme-propaganda .shortcut-item {
  border-bottom-color: rgba(198, 141, 34, 0.26);
}

.theme-propaganda .field-label,
.theme-propaganda .page-title,
.theme-propaganda .step-name,
.theme-propaganda .shortcut-title,
.theme-propaganda .sample-name,
.theme-propaganda .metric-value,
.theme-propaganda .link-text {
  color: #5d1010;
}
