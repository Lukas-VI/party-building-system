page {
  --brand-red: #b30f0f;
  --brand-red-dark: #7f0b0b;
  --brand-gold: #d3a339;
  --brand-surface: #fffdfb;
  --page-bg: #f5f2ee;
  --panel-bg: #ffffff;
  --panel-bg-strong: #fff6f1;
  --text-primary: #201717;
  --text-secondary: #584747;
  --text-muted: #7a6a6a;
  --line: #d7c9c9;
  --line-strong: #cdb8b8;
  --success: #1e6b45;
  --warning: #8a5400;
  --danger: #9f1111;
  --shadow-card: 0 12rpx 28rpx rgba(74, 28, 28, 0.08);
  background: var(--page-bg);
  color: var(--text-primary);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea,
scroll-view,
navigator {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx;
  background: var(--page-bg);
}

.theme-classic {
  --panel-bg: #ffffff;
  --panel-bg-strong: #fff8f4;
  --text-primary: #201717;
  --text-secondary: #584747;
  --text-muted: #7a6a6a;
  --line: #d7c9c9;
  --line-strong: #cdb8b8;
  --shadow-card: 0 12rpx 28rpx rgba(74, 28, 28, 0.08);
}

.theme-propaganda {
  --panel-bg: #fff7ea;
  --panel-bg-strong: #fff1d8;
  --text-primary: #4b0909;
  --text-secondary: #6a2020;
  --text-muted: #7f4a2f;
  --line: #d7b56d;
  --line-strong: #cda04b;
  --shadow-card: 0 16rpx 34rpx rgba(103, 17, 17, 0.12);
}

.page-title {
  font-size: 40rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
}

.page-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.card {
  background: var(--panel-bg);
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  box-shadow: var(--shadow-card);
}

.section-card {
  margin-top: 24rpx;
  padding: 26rpx;
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.input-box,
.textarea-box,
.picker-box {
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--line-strong);
  background: var(--brand-surface);
  font-size: 28rpx;
  color: var(--text-primary);
}

.textarea-box {
  min-height: 200rpx;
}

.btn-primary,
.btn-secondary,
.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  padding: 0 28rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
  border: none;
}

.btn-primary {
  background: var(--brand-red);
  color: #fff;
}

.btn-secondary {
  background: var(--panel-bg-strong);
  color: var(--brand-red-dark);
  border: 1rpx solid var(--line-strong);
}

.btn-ghost {
  background: #fff;
  color: var(--brand-red);
  border: 1rpx solid var(--brand-red);
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.badge-primary {
  background: #f6dfdf;
  color: var(--brand-red-dark);
  border: 1rpx solid #e7c1c1;
}

.badge-success {
  background: #e6f2eb;
  color: var(--success);
  border: 1rpx solid #b9d8c6;
}

.badge-warning {
  background: #fff0d8;
  color: var(--warning);
  border: 1rpx solid #edd1a1;
}

.badge-danger {
  background: #f9dddd;
  color: var(--danger);
  border: 1rpx solid #e6b1b1;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.metric-card {
  padding: 22rpx;
  border-radius: 16rpx;
  background: var(--panel-bg-strong);
  border: 1rpx solid var(--line);
}

.metric-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.metric-value {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--brand-red-dark);
}

.metric-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.link-text {
  color: var(--brand-red-dark);
  font-size: 24rpx;
  font-weight: 700;
}

.footer-note {
  margin-top: 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.hero-slogan,
.dashboard-banner,
.workflow-banner,
.register-banner,
.detail-banner,
.profile-banner {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid var(--line-strong);
  background: var(--panel-bg-strong);
  color: var(--text-secondary);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.6;
  text-align: center;
}

.theme-propaganda .card {
  border-color: var(--line-strong);
}

.theme-propaganda .metric-card,
.theme-propaganda .hero-panel,
.theme-propaganda .dashboard-hero,
.theme-propaganda .step-card {
  border-color: var(--line-strong);
}

@media (max-width: 420px) {
  .metric-grid {
    grid-template-columns: 1fr;
  }
}
