page {
  --brand-red: #c61f1f;
  --brand-red-dark: #8f1010;
  --brand-soft: #fff8f6;
  --surface: #ffffff;
  --text-primary: #2a1b1b;
  --text-secondary: #6f5b5b;
  --text-muted: #9f8d8d;
  --line: #ead8d8;
  --success: #1f8a5b;
  --warning: #b86800;
  --danger: #c9372c;
  --shadow-card: 0 18rpx 48rpx rgba(90, 22, 22, 0.08);
  background:
    radial-gradient(circle at top, #fff4ef 0%, #f7f4f1 38%, #f3f2ef 100%);
  color: var(--text-primary);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea,
scroll-view,
navigator {
  box-sizing: border-box;
}

.page-shell {
  min-height: 100vh;
  padding: 32rpx;
}

.page-title {
  font-size: 44rpx;
  line-height: 1.3;
  font-weight: 700;
}

.page-subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.card {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(198, 31, 31, 0.08);
  border-radius: 28rpx;
  box-shadow: var(--shadow-card);
}

.section-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.field-label {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.input-box,
.textarea-box,
.picker-box {
  width: 100%;
  min-height: 92rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid var(--line);
  background: var(--brand-soft);
  font-size: 28rpx;
  color: var(--text-primary);
}

.textarea-box {
  min-height: 200rpx;
}

.btn-primary,
.btn-secondary,
.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 1;
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--brand-red) 0%, var(--brand-red-dark) 100%);
  color: #fff;
  box-shadow: 0 18rpx 40rpx rgba(198, 31, 31, 0.24);
}

.btn-secondary {
  background: #f7e6e6;
  color: var(--brand-red-dark);
}

.btn-ghost {
  background: transparent;
  color: var(--brand-red);
  border: 1rpx solid rgba(198, 31, 31, 0.24);
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.badge-primary {
  background: rgba(198, 31, 31, 0.12);
  color: var(--brand-red-dark);
}

.badge-success {
  background: rgba(31, 138, 91, 0.12);
  color: var(--success);
}

.badge-warning {
  background: rgba(184, 104, 0, 0.12);
  color: var(--warning);
}

.badge-danger {
  background: rgba(201, 55, 44, 0.12);
  color: var(--danger);
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.metric-card {
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(255, 248, 246, 0.96) 0%, #fff 100%);
  border: 1rpx solid rgba(198, 31, 31, 0.08);
}

.metric-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.metric-value {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--brand-red-dark);
}

.metric-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.link-text {
  color: var(--brand-red);
  font-size: 26rpx;
}

.footer-note {
  margin-top: 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
}
