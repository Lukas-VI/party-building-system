.login-page {
  padding-top: 44rpx;
}

.hero-panel {
  padding: 48rpx 36rpx;
  background: linear-gradient(160deg, #8f1010 0%, #c61f1f 52%, #dd5a43 100%);
  color: #fff;
  text-align: center;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.4;
}

.hero-subtitle {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.84);
}

.hero-emblem {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  margin: 36rpx auto 0;
  border-radius: 50%;
  background: radial-gradient(circle, #f9df92 0%, #f1c45f 65%, #d9a83d 100%);
  box-shadow: inset 0 0 0 8rpx rgba(255, 255, 255, 0.18);
}

.hero-emblem-ring {
  position: absolute;
  inset: 18rpx;
  border: 3rpx solid rgba(143, 16, 16, 0.28);
  border-radius: 50%;
}

.hero-emblem-core {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  font-weight: 700;
  color: #8f1010;
}

.login-field-gap {
  margin-top: 24rpx;
}

.login-btn {
  margin-top: 28rpx;
}

.login-sub-btn {
  margin-top: 16rpx;
}

.sample-title {
  font-size: 30rpx;
}

.sample-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.sample-chip {
  padding: 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid #d7c9c9;
  background: #fff8f4;
}

.sample-chip-role {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.sample-chip-account {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
}
