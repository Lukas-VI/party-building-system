<view class="page-shell {{themeClass}}" wx:if="{{dashboard}}">
  <view class="card section-card dashboard-hero">
    <view class="row-between">
      <view>
        <view class="page-title dashboard-title">{{dashboard.welcome}}</view>
        <view class="page-subtitle">{{user.orgName}} {{user.branchName}}</view>
      </view>
      <view class="badge badge-primary">{{dashboard.scopeLabel}}</view>
    </view>
    <view class="dashboard-stage">当前定位：{{dashboard.currentStage}}</view>
    <view class="dashboard-summary">{{roleSummary}}</view>
    <view wx:if="{{themeMode === 'propaganda'}}" class="dashboard-banner">坚定理想信念  严格发展程序  强化过程留痕</view>
  </view>

  <view class="section-card card">
    <view class="page-title section-title">关键指标</view>
    <view class="metric-grid" style="margin-top: 24rpx;">
      <block wx:for="{{dashboard.metrics}}" wx:key="label">
        <view class="metric-card">
          <view class="metric-label">{{item.label}}</view>
          <view class="metric-value">{{item.value}}</view>
          <view class="metric-desc">{{item.desc}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="section-card card">
    <view class="page-title section-title">快捷入口</view>
    <block wx:for="{{shortcuts}}" wx:key="title">
      <view class="shortcut-item" data-url="{{item.url}}" bindtap="goAction">
        <view>
          <view class="shortcut-title">{{item.title}}</view>
          <view class="shortcut-desc">{{item.desc}}</view>
        </view>
        <view class="link-text">进入</view>
      </view>
    </block>
  </view>

  <view class="section-card card">
    <view class="page-title section-title">{{processGuidance.noticeTitle}}</view>
    <view class="page-subtitle notice-intro">{{processGuidance.noticeIntro}}</view>
    <block wx:for="{{processGuidance.rules}}" wx:key="*this">
      <view class="notice-item">
        <view class="notice-index">{{index + 1}}</view>
        <view class="notice-text">{{item}}</view>
      </view>
    </block>
  </view>

  <view class="section-card card">
    <view class="page-title section-title">流程示意</view>
    <block wx:for="{{processGuidance.stages}}" wx:key="code">
      <view class="flow-stage">
        <view class="row-between flow-stage-header">
          <view class="flow-stage-title">{{item.title}} · {{item.subtitle}}</view>
          <view class="badge badge-primary">{{item.stepRange}}</view>
        </view>
        <view class="flow-stage-summary">{{item.summary}}</view>
      </view>
    </block>
    <block wx:for="{{processGuidance.legends}}" wx:key="*this">
      <view class="flow-legend">{{item}}</view>
    </block>
  </view>

  <button class="btn-ghost" style="margin-top: 24rpx;" bindtap="logout">退出登录</button>
</view>
