.dashboard-hero {
  background: linear-gradient(135deg, rgba(198, 31, 31, 0.12) 0%, rgba(255, 255, 255, 0.96) 68%);
}

.dashboard-title {
  font-size: 36rpx;
}

.dashboard-stage {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(198, 31, 31, 0.1);
  font-size: 26rpx;
  color: var(--text-secondary);
}

.dashboard-summary {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.section-title {
  font-size: 30rpx;
}

.shortcut-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #f0dede;
}

.shortcut-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.shortcut-title {
  font-size: 28rpx;
  font-weight: 600;
}

.shortcut-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.notice-intro {
  margin-bottom: 18rpx;
}

.notice-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e4d5d5;
}

.notice-item:last-child {
  border-bottom: none;
}

.notice-index {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #8f1010;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notice-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-primary);
}

.flow-stage {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #e4d5d5;
}

.flow-stage:last-of-type {
  border-bottom: none;
}

.flow-stage-header {
  align-items: flex-start;
}

.flow-stage-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
  color: var(--text-primary);
}

.flow-stage-summary {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.flow-legend {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}
