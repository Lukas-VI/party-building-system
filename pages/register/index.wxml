<view class="page-shell">
  <view>
    <view class="page-title">首次注册</view>
    <view class="page-subtitle">提交姓名、身份证号、学号或工号，管理人员审核通过后才可正式登录。</view>
  </view>

  <view class="section-card card">
    <view class="field-label">姓名</view>
    <input class="input-box" placeholder="请输入真实姓名" data-field="name" bindinput="onChange" />

    <view class="field-label" style="margin-top: 24rpx;">身份证号</view>
    <input class="input-box" placeholder="请输入18位身份证号" data-field="idNo" bindinput="onChange" />

    <view class="field-label" style="margin-top: 24rpx;">学号 / 工号</view>
    <input class="input-box" placeholder="请输入学号或工号" data-field="username" bindinput="onChange" />

    <view class="field-label" style="margin-top: 24rpx;">注册角色</view>
    <view class="picker-box">入党申请人</view>

    <button class="btn-primary" style="margin-top: 32rpx;" bindtap="handleSubmit">提交注册</button>
  </view>
</view>
