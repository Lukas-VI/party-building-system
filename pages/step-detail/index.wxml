<view class="page-shell" wx:if="{{step}}">
  <view class="card section-card">
    <view class="row-between">
      <view class="page-title step-detail-title">{{step.name}}</view>
      <view class="badge {{step.statusClassName}}">{{step.statusText}}</view>
    </view>
    <view class="page-subtitle">阶段：{{step.phase}} · 截止时间：{{step.deadline}}</view>
  </view>

  <view class="card section-card">
    <view class="field-label">摘要说明</view>
    <textarea class="textarea-box" placeholder="填写本步骤的关键信息摘要" value="{{summary}}" data-field="summary" bindinput="onInput"></textarea>

    <view class="field-label" style="margin-top: 24rpx;">办理备注</view>
    <textarea class="textarea-box" placeholder="记录审核意见、参会信息或教育考察情况" value="{{note}}" data-field="note" bindinput="onInput"></textarea>

    <view class="field-label" style="margin-top: 24rpx;">附件</view>
    <button class="btn-secondary" bindtap="chooseImage">选择图片附件</button>
    <block wx:for="{{attachments}}" wx:key="fileUrl">
      <view class="attachment-item">{{item.fileName || item.storageName || item.fileUrl}}</view>
    </block>
  </view>

  <view class="card section-card">
    <view class="field-label">操作记录</view>
    <view class="log-item">最后办理人：{{step.lastOperator || '暂未记录'}}</view>
    <view class="log-item">操作时间：{{step.operatedAt || '暂未记录'}}</view>
    <view class="log-item">审核意见：{{step.reviewComment || '无'}}</view>
  </view>

  <button class="btn-primary" bindtap="saveAs" data-status="reviewing">提交 / 更新</button>
  <button wx:if="{{user.primaryRole !== 'applicant'}}" class="btn-secondary" style="margin-top: 16rpx;" bindtap="saveAs" data-status="approved">审核通过</button>
  <button wx:if="{{user.primaryRole !== 'applicant'}}" class="btn-ghost" style="margin-top: 16rpx;" bindtap="saveAs" data-status="rejected">审核退回</button>
</view>
