<view class="page-shell {{themeClass}}">
  <view>
    <view class="page-title">个人资料维护</view>
    <view class="page-subtitle">{{profileLayout.intro}}</view>
    <view wx:if="{{themeMode === 'propaganda'}}" class="profile-banner">信息真实准确  材料规范完整  过程留痕可追溯</view>
  </view>

  <view class="section-card card">
    <view class="field-label">微信绑定状态</view>
    <view class="picker-box">{{wechatStatus.bound ? '已绑定微信账号' : '未绑定微信账号'}}</view>
    <view wx:if="{{wechatStatus.bound}}" class="field-label" style="margin-top: 16rpx;">最近微信登录：{{wechatStatus.binding.lastLoginAt || '暂无记录'}}</view>
    <button wx:if="{{!wechatStatus.bound}}" class="btn-secondary" style="margin-top: 20rpx;" bindtap="bindWechat">绑定微信账号</button>
    <button wx:if="{{wechatStatus.bound}}" class="btn-ghost" style="margin-top: 20rpx;" bindtap="unbindWechat">解除微信绑定</button>
  </view>

  <block wx:for="{{renderSections}}" wx:for-item="section" wx:key="title">
    <view class="section-card card">
      <view class="page-title profile-section-title">{{section.title}}</view>
      <block wx:for="{{section.fields}}" wx:for-item="field" wx:key="key">
        <view class="field-block">
          <view class="field-label">{{field.label}}</view>
          <textarea
            wx:if="{{field.type === 'textarea'}}"
            class="textarea-box"
            value="{{field.value}}"
            data-field="{{field.key}}"
            placeholder="{{field.placeholder}}"
            bindinput="onInput"
          ></textarea>
          <view wx:elif="{{field.type === 'display'}}" class="picker-box">{{field.value || field.emptyText || '未填写'}}</view>
          <input
            wx:else
            class="input-box"
            value="{{field.value}}"
            data-field="{{field.key}}"
            placeholder="{{field.placeholder}}"
            bindinput="onInput"
          />
        </view>
      </block>
    </view>
  </block>

  <button class="btn-primary" style="margin-top: 28rpx;" bindtap="saveProfile">保存资料</button>

  <view class="section-card card">
    <view class="field-label">更多选项</view>
    <view class="picker-box">当前：{{themeLabel}} · {{colorSchemeLabel}}</view>
    <button class="btn-secondary settings-btn" bindtap="toggleTheme">切换样式</button>
  </view>
</view>
